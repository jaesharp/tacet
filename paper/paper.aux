\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces False positive rate by autocorrelation structure (null effect, shift pattern, W$_1$ distance statistic). Orange indicates false positives, taupe indicates correct ``no effect found'', teal indicates inconclusive (\textsc  {Tacet}\xspace  only). Under strong positive autocorrelation ($\rho = 0.8$), classical tools show 7--40\% false positive rates while \textsc  {Tacet}\xspace  achieves 0\% FPR by returning Inconclusive when precision is insufficient rather than forcing unreliable verdicts.}}{8}{figure.caption.27}\protected@file@percent }
\providecommand*\caption@xref[2]{\@setref\relax\@undefined{#1}}
\newlabel{fig:fpr_heatmap}{{1}{8}{False positive rate by autocorrelation structure (null effect, shift pattern, W$_1$ distance statistic). Orange indicates false positives, taupe indicates correct ``no effect found'', teal indicates inconclusive (\tacet only). Under strong positive autocorrelation ($\rho = 0.8$), classical tools show 7--40\% false positive rates while \tacet achieves 0\% FPR by returning Inconclusive when precision is insufficient rather than forcing unreliable verdicts}{figure.caption.27}{}}
\newlabel{fig:fpr_heatmap@cref}{{[figure][1][]1}{[1][7][]8}{}{}{}}
