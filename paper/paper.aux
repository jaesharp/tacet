\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces Detection power by effect size under AR(1) noise with $\rho = 0.6$ (W$_1$ distance statistic). Each tool has three sub-rows for shift, tail (upper 5\%), and bimodal effect patterns. Bimodal effects show strongest detection across all tools---W$_1$'s integration of CDF differences captures the full mode separation. All tools achieve 100\% detection at $\geq 20\sigma $ (omitted). \textsc  {Tacet}\xspace  returns Inconclusive when precision is insufficient.}}{9}{figure.caption.29}\protected@file@percent }
\newlabel{fig:power_heatmap}{{2}{9}{Detection power by effect size under AR(1) noise with $\rho = 0.6$ (W$_1$ distance statistic). Each tool has three sub-rows for shift, tail (upper 5\%), and bimodal effect patterns. Bimodal effects show strongest detection across all tools---W$_1$'s integration of CDF differences captures the full mode separation. All tools achieve 100\% detection at $\geq 20\sigma $ (omitted). \tacet returns Inconclusive when precision is insufficient}{figure.caption.29}{}}
\newlabel{fig:power_heatmap@cref}{{[figure][2][]2}{[1][7][]9}{}{}{}}
