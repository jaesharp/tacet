\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces False positive rate by autocorrelation structure (null effect, shift pattern, W$_1$ distance statistic). Teal indicates ``effect found'' (false positive), taupe indicates ``effect not found'' (correct), orange indicates ``could not determine'' (\textsc  {Tacet}\xspace  only). Under strong autocorrelation, tools assuming independence show elevated FPR while \textsc  {Tacet}\xspace  returns Inconclusive.}}{7}{figure.caption.25}\protected@file@percent }
\providecommand*\caption@xref[2]{\@setref\relax\@undefined{#1}}
